---
// The password output + strength bar. This is the single most
// important element on the page, so it gets the most visual weight:
// large monospace text, generous padding, and a light card-within-card
// treatment so it doesn't look like a disabled form input.
---

<div class="mb-6">
  <!-- Security badge — replaces the old full-width green banner. Small,
       contextual, sits right where trust actually matters: next to the
       thing being generated. -->
  <div
    class="inline-flex items-center gap-1.5 text-xs font-medium text-emerald-700 bg-emerald-50 border border-emerald-200 rounded-full px-3 py-1 mb-4 dark:text-emerald-300 dark:bg-emerald-950 dark:border-emerald-900"
  >
    🛡 Runs entirely in your browser — no data ever leaves your device
  </div>

  <div class="passphrase-stage">
    <div class="flex items-center justify-between gap-3 text-sm font-semibold text-slate-600 dark:text-slate-300">
      <span class="inline-flex items-center gap-2"><span class="passphrase-icon">🔒</span> Secure passphrase</span>
      <button id="copy-inline-btn" type="button" class="inline-flex h-9 w-9 items-center justify-center rounded-lg border border-orange-200 bg-white/80 text-base shadow-sm transition hover:-translate-y-0.5 hover:border-brand-300 hover:shadow-md focus:outline-none focus-visible:ring-2 focus-visible:ring-brand-300 dark:border-orange-900 dark:bg-slate-800" aria-label="Copy passphrase" title="Copy passphrase">📋</button>
    </div>
    <div
      id="passphrase-output"
      class="font-mono font-bold text-[27px] sm:text-4xl md:text-[42px] text-left leading-tight mt-5 min-h-24 flex items-center text-slate-950 transition-opacity duration-200 [overflow-wrap:anywhere] dark:text-white"
      aria-live="polite"
    >
      Generating&hellip;
    </div>
    <div class="passphrase-stage-glow"></div>
  </div>

  <!-- Fallback copy field, hidden unless Clipboard API is unavailable -->
  <input
    id="fallback-copy-field"
    type="text"
    readonly
    class="hidden mt-2 w-full text-center font-mono text-sm border border-slate-300 rounded-lg py-2 px-3 dark:border-slate-600 dark:bg-slate-900 dark:text-white"
  />

  <!-- Strength bar -->
  <div class="mt-5 rounded-2xl border border-slate-100 bg-slate-50/80 px-4 py-4 dark:border-slate-700 dark:bg-slate-900/60">
    <div class="flex items-center justify-between text-sm mb-3">
      <span class="flex flex-col gap-0.5">
        <span id="strength-text" class="font-bold text-slate-800 dark:text-slate-100">&nbsp;</span>
        <span class="text-xs text-slate-500 dark:text-slate-400">Estimate based on current generator settings</span>
      </span>
      <span class="inline-flex items-center gap-1.5">
        <span id="entropy-bits-label" class="text-slate-400 dark:text-slate-500"
          >&nbsp;</span
        >
        <span class="relative inline-flex group">
          <button
            type="button"
            id="entropy-info-btn"
            aria-label="What does this entropy value mean?"
            class="w-4 h-4 flex items-center justify-center rounded-full border border-slate-400 text-slate-400 text-[10px] leading-none transition-colors hover:border-brand-500 hover:text-brand-500 focus:outline-none focus-visible:ring-2 focus-visible:ring-brand-300 dark:border-slate-500 dark:text-slate-400 dark:hover:border-brand-dark dark:hover:text-brand-dark"
          >
            i
          </button>
          <span
            id="entropy-tooltip"
            role="tooltip"
            class="hidden absolute z-10 bottom-full right-0 mb-2 w-64 text-xs text-left text-slate-600 bg-white border border-slate-200 rounded-lg shadow-lg p-3 opacity-0 scale-95 transition-all duration-150 dark:bg-slate-900 dark:border-slate-700 dark:text-slate-300"
          >
            Entropy estimates how difficult a password is to guess. This
            value is based on your current settings, including word count,
            wordlist size, number, and symbol options. It stays the same for
            the same configuration, even when a new random phrase is
            generated.
          </span>
        </span>
      </span>
    </div>
    <div
      class="h-2.5 w-full rounded-full bg-slate-200 dark:bg-slate-700 overflow-hidden"
    >
      <div
        id="strength-bar-fill"
        class="h-full rounded-full transition-all duration-500 ease-out bg-red-500"
        style="width: 0%"
      >
      </div>
    </div>
  </div>

  <div
    id="crypto-error"
    class="hidden mt-3 text-sm text-red-600 text-center dark:text-red-400"
  >
    Your browser doesn't support the secure randomness this tool requires
    (Web Crypto API). Please try an up-to-date browser.
  </div>
</div>
