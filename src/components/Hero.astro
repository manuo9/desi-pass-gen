---
// Simple, single-purpose hero: one heading, one supporting line.
// The generator card below is the actual hero of the page — this just
// introduces it.
---

<section class="hero-surface relative overflow-hidden pt-10 sm:pt-20 pb-32 sm:pb-40 text-center">
  <div class="hero-orb hero-orb-left"></div>
  <div class="hero-orb hero-orb-right"></div>
  <div class="relative max-w-4xl mx-auto px-6">
    <div class="inline-flex items-center gap-2 rounded-full border border-brand-100 bg-white/80 px-4 py-2 text-sm font-semibold text-brand-700 shadow-sm backdrop-blur dark:border-brand-500/30 dark:bg-slate-900/70 dark:text-brand-dark">
      <span class="flex h-2 w-2 rounded-full bg-emerald-500"></span>
      Private by design. Always local.
    </div>
    <h1 class="mt-6 text-5xl sm:text-6xl lg:text-7xl font-extrabold text-slate-950 dark:text-white leading-[1.02] tracking-[-0.05em]">
      Generate Secure<br class="hidden sm:block" /> Hinglish passphrases.
    </h1>
    <p class="max-w-xl mx-auto mt-6 text-lg sm:text-xl leading-relaxed text-slate-600 dark:text-slate-300">
      Strong enough to protect what matters. Familiar enough to remember.
    </p>
  </div>
</section>
